
# ------------------------------------------------------------
# Frontend (Vite, public env vars; safe for browser exposure)
# ------------------------------------------------------------
# Keep AI disabled unless a secure backend proxy is configured.
VITE_ENABLE_AI=false
# Voice AI is on by default when backend keys are set. Set false to disable in browser.
# VITE_ENABLE_VOICE_AI=false
# Leave empty for local dev — the Vite proxy forwards /api to AUTH_API_PORT (localhost URLs are always treated as empty).
# Set to your staging/production API URL only when frontend and backend are on different origins.
VITE_API_BASE_URL=
VITE_SENTRY_DSN=
VITE_SENTRY_ENV=production
VITE_APP_RELEASE=
VITE_APP_STORE_URL=
VITE_GOOGLE_PLAY_URL=
VITE_EXPO_PREVIEW_URL=
# Public site URL for SEO (sitemap, robots, index.html meta tags):
VITE_SITE_URL=https://luna29.vercel.app
# Optional analytics (loaded only after user consent):
VITE_GA4_MEASUREMENT_ID=

# Google OAuth Web Client ID — Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs.
# Required for Google sign-in button to appear. Must also be set in AUTH_GOOGLE_CLIENT_IDS on the server.
VITE_GOOGLE_CLIENT_ID=

# ------------------------------------------------------------
# Backend Auth / Session / Admin
# ------------------------------------------------------------
# AUTH_API_PORT=8787
SUPER_ADMIN_EMAILS=dnainform@gmail.com
SUPER_ADMIN_BOOTSTRAP_PASSWORD=change-me-now
# Local dev only — mirrors SUPER_ADMIN_BOOTSTRAP_PASSWORD for client-side fallback login button.
# VITE_DEV_SUPER_ADMIN_PASSWORD=change-me-now
# AUTH_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://luna29.vercel.app

# Comma-separated Google OAuth audiences — must match VITE_GOOGLE_CLIENT_ID (recommended for production).
# AUTH_GOOGLE_CLIENT_IDS=your-google-client-id.apps.googleusercontent.com

# Unsafe dev-only switch. Keep false in production.
# AUTH_ALLOW_UNVERIFIED_GOOGLE=true

# ------------------------------------------------------------
# AI Processing (server-side only)
# ------------------------------------------------------------
# GEMINI_API_KEY=your-gemini-key
# GEMINI_VOICE_MODEL=gemini-2.5-flash
# API_KEY=legacy-fallback-key

# ElevenLabs — Luna voice (TTS). Create voices at https://elevenlabs.io
# ELEVENLABS_API_KEY=sk_...
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2
# Default voice (Rachel): EXAVITQu4vr4xnSDxMaL
# ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
# Persona overrides (optional — same spirit, different tone):
# ELEVENLABS_VOICE_LUNA=EXAVITQu4vr4xnSDxMaL
# ELEVENLABS_VOICE_LUNA_SOFT=XB0fDUnXU5powFXDhCwa
# ELEVENLABS_VOICE_LUNA_CLEAR=21m00Tcm4TlvDq8ikWAM

# Optional backend error monitoring:
# SENTRY_DSN=

# ------------------------------------------------------------
# Database (optional Postgres — Neon/Vercel Postgres)
# ------------------------------------------------------------
# When set, server persists KV state and trials in Postgres instead of JSON files.
# DATABASE_URL=postgresql://user:pass@host:5432/luna29?sslmode=require

# ------------------------------------------------------------
# Rate limiting (optional Upstash Redis — production recommended)
# ------------------------------------------------------------
# When both are set, API rate limits use Upstash; otherwise in-memory fallback.
# UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ------------------------------------------------------------
# Billing (Stripe)
# ------------------------------------------------------------
# STRIPE_BILLING_ENABLED=false
# STRIPE_SECRET_KEY=sk_live_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# STRIPE_PRICE_MONTHLY_ID=price_xxx
# STRIPE_PRICE_YEARLY_ID=price_xxx
# STRIPE_SUCCESS_URL=https://your-domain.com/member?billing=success
# STRIPE_CANCEL_URL=https://your-domain.com/pricing?billing=canceled
# STRIPE_PORTAL_RETURN_URL=https://your-domain.com/profile
# STRIPE_TRIAL_DAYS=7

# For Vercel production, allow your deployed domains:
# AUTH_ALLOWED_ORIGINS=https://your-project.vercel.app,https://your-custom-domain.com

# Optional auto-translation provider for content created in Admin panel.
# In local mode set these in browser localStorage:
# - luna_translate_api_url
# - luna_translate_api_key
