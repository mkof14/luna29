
# ------------------------------------------------------------
# Frontend (Vite, public env vars; safe for browser exposure)
# ------------------------------------------------------------
# Keep AI disabled unless a secure backend proxy is configured.
VITE_ENABLE_AI=false
VITE_API_BASE_URL=
VITE_SENTRY_DSN=
VITE_SENTRY_ENV=production
VITE_APP_RELEASE=
VITE_APP_STORE_URL=
VITE_GOOGLE_PLAY_URL=
VITE_EXPO_PREVIEW_URL=
# Public site URL for SEO (sitemap, robots, index.html meta tags):
VITE_SITE_URL=https://luna29.vercel.app
# Optional analytics (loaded only after user consent):
VITE_GA4_MEASUREMENT_ID=

# Optional compatibility fallback (backend reads AUTH_GOOGLE_CLIENT_IDS first).
VITE_GOOGLE_CLIENT_ID=

# ------------------------------------------------------------
# Backend Auth / Session / Admin
# ------------------------------------------------------------
# AUTH_API_PORT=8787
# SUPER_ADMIN_EMAILS=dnainform@gmail.com
# SUPER_ADMIN_BOOTSTRAP_PASSWORD=change-me-now
# AUTH_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:4173,http://127.0.0.1:4173

# Comma-separated Google OAuth audiences (recommended for production).
# AUTH_GOOGLE_CLIENT_IDS=your-google-client-id.apps.googleusercontent.com

# Unsafe dev-only switch. Keep false in production.
# AUTH_ALLOW_UNVERIFIED_GOOGLE=false

# ------------------------------------------------------------
# AI Processing (server-side only)
# ------------------------------------------------------------
# GEMINI_API_KEY=your-gemini-key
# API_KEY=legacy-fallback-key

# Optional backend error monitoring:
# SENTRY_DSN=

# ------------------------------------------------------------
# Billing (Stripe)
# ------------------------------------------------------------
# STRIPE_BILLING_ENABLED=false
# STRIPE_SECRET_KEY=sk_live_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# STRIPE_PRICE_MONTHLY_ID=price_xxx
# STRIPE_PRICE_YEARLY_ID=price_xxx
# STRIPE_SUCCESS_URL=https://your-domain.com/member?billing=success
# STRIPE_CANCEL_URL=https://your-domain.com/pricing?billing=canceled
# STRIPE_PORTAL_RETURN_URL=https://your-domain.com/profile
# STRIPE_TRIAL_DAYS=7

# For Vercel production, allow your deployed domains:
# AUTH_ALLOWED_ORIGINS=https://your-project.vercel.app,https://your-custom-domain.com

# Optional auto-translation provider for content created in Admin panel.
# In local mode set these in browser localStorage:
# - luna_translate_api_url
# - luna_translate_api_key
