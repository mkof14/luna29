{
  "expo": {
    "name": "Luna29",
    "slug": "luna-mobile",
    "version": "1.0.0",
    "scheme": "luna",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f5eff7"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mkof14.lunamobile",
      "infoPlist": {
        "NSUserNotificationsUsageDescription": "Luna29 uses notifications for gentle evening reflection reminders.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.mkof14.lunamobile",
      "adaptiveIcon": {
        "backgroundColor": "#f5eff7",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#b974cc"
        }
      ],
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "814bf5a6-408a-49ae-922b-1bab936b39f9"
      }
    },
    "owner": "mkof14"
  }
}
