{
  "name": "luna-balance",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:full": "node --env-file-if-exists=.env.local server/index.mjs & vite",
    "api": "node --env-file-if-exists=.env.local server/index.mjs",
    "build": "node scripts/generate-seo-assets.mjs && tsc && vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "test:smoke": "rm -rf .tmp-tests && tsc -p tsconfig.tests.json && echo '{\"type\":\"commonjs\"}' > .tmp-tests/package.json && node .tmp-tests/tests/run-smoke.js",
    "ci:check": "npm run lint && npm run test:smoke && npm run build && npm run perf:bundle",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "smoke:deploy": "node scripts/post-deploy-smoke.mjs",
    "perf:bundle": "node scripts/perf-budget.mjs",
    "qa:beta": "node scripts/qa-beta.mjs",
    "qa:beta:strict": "node scripts/qa-beta.mjs --strict",
    "release:ready": "node scripts/release-ready.mjs"
  },
  "dependencies": {
    "@google/genai": "^1.40.0",
    "lucide-react": "^0.575.0",
    "motion": "^12.34.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.7.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "vite": "^6.0.0"
  }
}
